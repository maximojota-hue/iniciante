# Copie este arquivo para .env e preencha com seus dados.

# Claude API
ANTHROPIC_API_KEY=sk-ant-api03-...

# Clube 3D Brasil - WordPress Application Password
WP_USER=seu_email@exemplo.com
WP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx

# Pinterest API
PINTEREST_ACCESS_TOKEN=...
PINTEREST_BOARD_ID=...

# Telegram
# Crie um bot no @BotFather, adicione no grupo e use o chat_id do grupo.
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_ENABLED=true
TELEGRAM_NOTIFY_STATUSES=publish

# Helio Brinquedos usa arquivo separado: .env.helio
